1.
# Hàm in ra đường viền ngang
def print_beam():
    # Nhân chuỗi '+ - - - - ' lên 2 lần, sau đó cộng thêm dấu '+' ở cuối
    print('+ - - - - ' * 2 + '+')

# Hàm in ra các cột dọc
def print_post():
    # Nhân chuỗi '|         ' lên 2 lần, sau đó cộng thêm dấu '|' ở cuối
    print('|         ' * 2 + '|')

# Hàm in ra 1 "hàng" hoàn chỉnh (gồm 1 viền ngang và 4 dòng cột dọc)
def print_row():
    print_beam()
    print_post()
    print_post()
    print_post()
    print_post()

# Hàm vẽ toàn bộ lưới 2x2
def print_grid():
    print_row()  # Hàng thứ nhất
    print_row()  # Hàng thứ hai
    print_beam() # Đóng viền dưới cùng

print("1. Lưới 2x2:")
print_grid()

