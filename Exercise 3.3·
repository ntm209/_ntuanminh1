def print_beam_4():
    print('+ - - - - ' * 4 + '+')

def print_post_4():
    print('|         ' * 4 + '|')

def print_row_4():
    print_beam_4()
    print_post_4()
    print_post_4()
    print_post_4()
    print_post_4()

def print_grid_4():
    print_row_4()
    print_row_4()
    print_row_4()
    print_row_4()
    print_beam_4() # Đóng viền dưới cùng

print("\n2. Lưới 4x4:")
print_grid_4()
