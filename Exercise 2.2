#Bài tập 2.2

import math

# --- Câu 1: Thể tích hình cầu ---
radius = 5
volume = (4/3) * math.pi * (radius**3)
print(f"1. Thể tích hình cầu bán kính 5 là: {volume:.2f}")

# --- Câu 2: Tính giá sỉ sách ---
cover_price = 24.95
discount = 0.40
copies = 60

# Tính giá mỗi cuốn sau khi giảm
discounted_price = cover_price * (1 - discount)

# Tính phí vận chuyển (cuốn đầu $3, các cuốn sau $0.75)
shipping_cost = 3.00 + 0.75 * (copies - 1)

# Tổng chi phí
total_cost = (discounted_price * copies) + shipping_cost
print(f"2. Tổng chi phí bán buôn cho {copies} cuốn sách là: ${total_cost:.2f}")

# --- Câu 3: Tính thời gian chạy bộ ---
# Đổi thời gian xuất phát ra giây (tính từ nửa đêm)
start_hour = 6
start_minute = 52
start_time_seconds = (start_hour * 3600) + (start_minute * 60)

# Thời gian chạy cho mỗi dặm (tính bằng giây)
easy_pace_seconds = (8 * 60) + 15  # 8 phút 15 giây
tempo_pace_seconds = (7 * 60) + 12 # 7 phút 12 giây

# Tổng thời gian chạy (1 dặm easy + 3 dặm tempo + 1 dặm easy)
run_time_seconds = easy_pace_seconds + (3 * tempo_pace_seconds) + easy_pace_seconds

# Thời gian về đến nhà (tính bằng tổng số giây)
end_time_seconds = start_time_seconds + run_time_seconds

# Đổi ngược lại ra giờ, phút, giây
end_hour = end_time_seconds // 3600
end_minute = (end_time_seconds % 3600) // 60
end_second = end_time_seconds % 60

print(f"3. Thời gian về đến nhà ăn sáng là: {end_hour:02}:{end_minute:02}:{end_second:02} am")
