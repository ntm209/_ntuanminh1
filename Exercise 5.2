#Bài tập 5.1

import time
# Lấy tổng số giây tính từ thời điểm "epoch" (1/1/1970)
total_seconds = time.time()

# Định nghĩa các hằng số thời gian
seconds_per_minute = 60
seconds_per_hour = 60 * 60       # 3600 giây
seconds_per_day = 24 * 60 * 60   # 86400 giây

# 1. Tính số ngày kể từ epoch
# Chia lấy phần nguyên cho số giây trong 1 ngày
days_since_epoch = int(total_seconds // seconds_per_day)

# Lấy số giây còn dư lại của ngày hiện tại
seconds_remainder = total_seconds % seconds_per_day

# 2. Tính số giờ
# Chia số giây còn dư cho số giây trong 1 giờ
hours = int(seconds_remainder // seconds_per_hour)

# Lấy số giây còn dư sau khi đã tính giờ
seconds_remainder = seconds_remainder % seconds_per_hour

# 3. Tính số phút
# Chia số giây còn dư cho số giây trong 1 phút
minutes = int(seconds_remainder // seconds_per_minute)

# 4. Tính số giây còn lại
seconds = int(seconds_remainder % seconds_per_minute)

# In kết quả
print(f"Số ngày kể từ mốc Epoch (1/1/1970): {days_since_epoch} ngày")
print(f"Thời gian trong ngày (Giờ GMT): {hours:02d}:{minutes:02d}:{seconds:02d}")
