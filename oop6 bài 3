import math

# 1. Định nghĩa Custom Exception [3, 4]
class MauSoBangKhong(Exception):
    def __init__(self):
        super().__init__("Lỗi: Mẫu số phải khác 0!")

class PhanSo:
    def __init__(self, tu=0, mau=1):
        # Sử dụng setter để kiểm tra tính hợp lệ ngay khi khởi tạo [5]
        self.tu_so = tu
        self.mau_so = mau

    # 2. Đóng gói với @property [6, 7]
    @property
    def tu_so(self):
        return self._tu_so

    @tu_so.setter
    def tu_so(self, value):
        if not isinstance(value, int):
            raise TypeError("Tử số phải là số nguyên")
        self._tu_so = value

    @property
    def mau_so(self):
        return self._mau_so

    @mau_so.setter
    def mau_so(self, value):
        if not isinstance(value, int):
            raise TypeError("Mẫu số phải là số nguyên")
        if value == 0:
            raise MauSoBangKhong() # Ném ngoại lệ tùy chỉnh [1, 3]
        self._mau_so = value

    # 3. Phép tìm dạng tối giản [2]
    def toi_gian(self):
        common = math.gcd(self._tu_so, self._mau_so)
        return PhanSo(self._tu_so // common, self._mau_so // common)

    def is_toi_gian(self):
        return math.gcd(self._tu_so, self._mau_so) == 1

    # 4. Nạp chồng toán tử toán học (Operator Overloading) [3, 8, 9]
    def __add__(self, other):
        new_tu = self.tu_so * other.mau_so + other.tu_so * self.mau_so
        new_mau = self.mau_so * other.mau_so
        return PhanSo(new_tu, new_mau).toi_gian()

    def __sub__(self, other):
        new_tu = self.tu_so * other.mau_so - other.tu_so * self.mau_so
        new_mau = self.mau_so * other.mau_so
        return PhanSo(new_tu, new_mau).toi_gian()

    def __mul__(self, other):
        return PhanSo(self.tu_so * other.tu_so, self.mau_so * other.mau_so).toi_gian()

    def __truediv__(self, other):
        return PhanSo(self.tu_so * other.mau_so, self.mau_so * other.tu_so).toi_gian()

    # 5. Magic methods so sánh và hiển thị [3, 10, 11]
    def __eq__(self, other):
        # So sánh giá trị thực của hai phân số
        return self.tu_so * other.mau_so == other.tu_so * self.mau_so

    def __lt__(self, other):
        # Hỗ trợ hàm sorted() [12]
        return (self.tu_so / self.mau_so) < (other.tu_so / other.mau_so)

    def __str__(self):
        # Hiển thị số nguyên nếu mẫu = 1 [2]
        ps = self.toi_gian()
        if ps.mau_so == 1:
            return f"{ps.tu_so}"
        return f"{ps.tu_so}/{ps.mau_so}"

    def __repr__(self):
        return f"PhanSo({self.tu_so}, {self.mau_so})"

    def __hash__(self):
        # Hash theo dạng tối giản để set() loại trùng [3]
        ps = self.toi_gian()
        return hash((ps.tu_so, ps.mau_so))

# --- Chương trình ứng dụng ---
try:
    # Nhập dãy phân số
    ds_ps = [PhanSo(2, 4), PhanSo(3, 1), PhanSo(1, 3), PhanSo(5, 10)]
    
    print("Dãy phân số tối giản:")
    for ps in ds_ps:
        print(f"{ps.tu_so}/{ps.mau_so} -> {ps}")

    # Sắp xếp tăng dần nhờ __lt__
    print("\nDãy sau khi sắp xếp tăng dần:")
    for ps in sorted(ds_ps):
        print(ps)

    # Loại bỏ trùng lặp nhờ __hash__ và __eq__
    print("\nLoại bỏ các phân số trùng giá trị (ví dụ 2/4 và 5/10):")
    print(set(ds_ps))

except MauSoBangKhong as e:
    print(e)
except Exception as e:
    print(f"Lỗi không xác định: {e}")
